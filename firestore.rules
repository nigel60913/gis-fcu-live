rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function answerMatchesQuestionLimits(questionId) {
      let question = get(/databases/$(database)/documents/questions/$(questionId)).data;
      let value = request.resource.data.value;
      return (question.type != 'multi'
              || (value is list
                  && value.size() <= question.get('maxSelections', 100)))
             && (!(question.type in ['wordcloud', 'open'])
                 || (value is string
                     && value.size() <= question.get('wordLimit', 120)));
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /responses/{responseId} {
        allow read: if true;
        allow create, update: if request.resource.data.keys().hasOnly([
                                  'value', 'clientId', 'nickname', 'createdAt'
                                ])
                                && request.resource.data.clientId is string
                                && request.resource.data.clientId == responseId
                                && request.resource.data.clientId.size() <= 64
                                && request.resource.data.nickname is string
                                && request.resource.data.nickname.size() <= 12
                                && answerMatchesQuestionLimits(questionId);
        allow delete: if isSignedIn();
      }
    }

    match /session/{doc} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
