rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'nigel60913@gmail.com';
    }
    function currentSession() {
      return get(/databases/$(database)/documents/session/current).data;
    }
    function isQuestionLive(questionId) {
      return currentSession().activeQuestionId == questionId
        && currentSession().state == 'live'
        && (!('timerEndsAt' in currentSession())
          || currentSession().timerEndsAt == null
          || currentSession().timerEndsAt > request.time.toMillis());
    }
    function validResponse(responseId) {
      return request.resource.data.keys().hasOnly(['value','clientId','nickname','createdAt'])
        && request.resource.data.clientId is string
        && request.resource.data.clientId == responseId
        && request.resource.data.clientId.size() <= 64
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() <= 12;
    }
    match /questions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      match /responses/{responseId} {
        allow read: if true;
        allow create: if isQuestionLive(questionId) && validResponse(responseId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }
    match /session/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
